# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=bap_adventure
POSTGRES_USER=bap
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Constructed automatically in docker-compose.yml from vars above.
# For local dev outside Docker, set this directly:
DATABASE_URL=postgresql://bap:CHANGE_ME_STRONG_PASSWORD@localhost:5432/bap_adventure

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://YOUR_DOMAIN_OR_IP

# ─── AI ──────────────────────────────────────────────────────────────────────
AI_ENDPOINT=https://9router.remotestaff.vn/v1
AI_MODEL=advance-model
AI_API_KEY=CHANGE_ME

# ─── Next.js ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_RANDOM_32_CHARS
